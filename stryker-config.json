{
  "stryker-config": {
    "project": "Identity.Api/Identity.Api.csproj",
    "test-projects": [
      "Identity.Tests/Identity.Tests.csproj"
    ],
    "reporters": [
      "html",
      "json",
      "progress",
      "dashboard"
    ],
    "project-info": {
      "name": "github.com/crgolden/Identity",
      "version": "main"
    },
    "mutation-level": "Advanced",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 50
    },
    "mutate": [
      "EmailSender.cs",
      "GravatarService.cs",
      "Extensions/ConfigurationExtensions.cs",
      "Extensions/EndpointRouteBuilderExtensions.cs"
    ],
    "since": {
      "enabled": false
    },
    "additional-timeout": 30,
    "test-runner": "mtp",
    "coverage-analysis": "all",
    "test-case-filter": "Category=Unit"
  }
}
