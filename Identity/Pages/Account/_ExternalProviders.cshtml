@model IList<Microsoft.AspNetCore.Authentication.AuthenticationScheme>?
@{
    var returnUrl = ViewData["ReturnUrl"] as string;
    var actionVerb = ViewData["ActionVerb"] as string ?? "log in";
}

<section>
    <h3>Use another service to @actionVerb.</h3>
    <hr />
    @{
        if ((Model?.Count ?? 0) == 0)
        {
            <div>
                <p>
                    There are no external authentication services configured. See this <a href="https://go.microsoft.com/fwlink/?LinkID=532715">article
                    about setting up this ASP.NET application to support logging in via external services</a>.
                </p>
            </div>
        }
        else
        {
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@returnUrl" method="post" class="form-horizontal">
                <div>
                    <p>
                        @foreach (var provider in Model!)
                        {
                            <button id="@($"external-login-button-{provider.Name}")" type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                        }
                    </p>
                </div>
            </form>
        }
    }
</section>
