@page "{id:int}"
@model Identity.Pages.Admin.ApiScopes.Details.IndexModel
@{
    ViewData["Title"] = "API Scope Details";
}

<h1>API Scope: @Model.Scope.Name</h1>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Scope.Name</dd>
    <dt class="col-sm-3">Display Name</dt>
    <dd class="col-sm-9">@Model.Scope.DisplayName</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Scope.Description</dd>
    <dt class="col-sm-3">Enabled</dt>
    <dd class="col-sm-9">@Model.Scope.Enabled</dd>
    <dt class="col-sm-3">Required</dt>
    <dd class="col-sm-9">@Model.Scope.Required</dd>
    <dt class="col-sm-3">Emphasize</dt>
    <dd class="col-sm-9">@Model.Scope.Emphasize</dd>
    <dt class="col-sm-3">Show In Discovery</dt>
    <dd class="col-sm-9">@Model.Scope.ShowInDiscoveryDocument</dd>
</dl>

<div class="mb-3">
    <a id="nav-claimtypes" asp-page="./ClaimTypes" asp-route-id="@Model.Scope.Id" class="btn btn-outline-secondary btn-sm">Claim Types</a>
    <a id="nav-properties" asp-page="./Properties" asp-route-id="@Model.Scope.Id" class="btn btn-outline-secondary btn-sm">Properties</a>
    <a id="btn-edit" asp-page="../Edit/Index" asp-route-id="@Model.Scope.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
    <a id="btn-back" asp-page="../Index" class="btn btn-outline-secondary btn-sm">Back</a>
</div>
