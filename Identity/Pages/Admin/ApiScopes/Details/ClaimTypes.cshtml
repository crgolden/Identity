@page "{id:int}"
@model Identity.Pages.Admin.ApiScopes.Details.ClaimTypesModel
@{
    ViewData["Title"] = "API Scope Claim Types";
}

<h1>Claim Types: @Model.Scope.Name</h1>

@await Html.PartialAsync("~/Pages/Admin/Shared/_DetailsClaimTypesTable.cshtml",
    (Model.Scope.UserClaims ?? []).Select(c => new ClaimTypeRow(c.Id, c.Type)))

<a id="btn-back" asp-page="./Index" asp-route-id="@Model.Scope.Id" class="btn btn-outline-secondary btn-sm">Back</a>
<a id="btn-edit" asp-page="../Edit/ClaimTypes" asp-route-id="@Model.Scope.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
