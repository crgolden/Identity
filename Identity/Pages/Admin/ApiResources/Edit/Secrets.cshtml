@page "{id:int}"
@model Identity.Pages.Admin.ApiResources.Edit.SecretsModel
@{
    ViewData["Title"] = $"Edit Secrets – {Model.ResourceName}";
}

<h1>@Model.ResourceName — Edit Secrets</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="Secrets">
        <thead class="table-light">
            <tr><th>Description</th><th>Type</th><th>Expiration</th><th>Value (new only)</th><th></th></tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Secrets.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="Secrets[@i].Id" value="@Model.Secrets[i].Id" />
                    <td><input name="Secrets[@i].Description" value="@Model.Secrets[i].Description" class="form-control form-control-sm" aria-label="Description" /></td>
                    <td><input name="Secrets[@i].Type" value="@Model.Secrets[i].Type" class="form-control form-control-sm" aria-label="Secret type" /></td>
                    <td><input name="Secrets[@i].Expiration" value="@Model.Secrets[i].Expiration" type="datetime-local" class="form-control form-control-sm" aria-label="Expiration" /></td>
                    <td></td>
                    <td><button data-remove-row class="btn btn-sm btn-danger">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="Secrets">
        <tr data-row>
            <input type="hidden" name="Secrets[-1].Id" value="0" />
            <td><input name="Secrets[-1].Description" class="form-control form-control-sm" aria-label="Description" /></td>
            <td><input name="Secrets[-1].Type" value="SharedSecret" class="form-control form-control-sm" aria-label="Secret type" /></td>
            <td><input name="Secrets[-1].Expiration" type="datetime-local" class="form-control form-control-sm" aria-label="Expiration" /></td>
            <td><input name="Secrets[-1].Value" type="password" class="form-control form-control-sm" placeholder="Value" aria-label="Secret value" /></td>
            <td><button data-remove-row class="btn btn-sm btn-danger">Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" data-add-for="Secrets" class="btn btn-sm btn-outline-secondary mb-3">Add Secret</button>
    <div>
        <button id="save-submit" type="submit" class="btn btn-primary">Save</button>
        <a asp-page="../Details/Secrets" asp-route-id="@HttpContext.Request.RouteValues["id"]" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
