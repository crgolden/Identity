@page "{id:int}"
@model Identity.Pages.Admin.ApiResources.Edit.PropertiesModel
@{
    ViewData["Title"] = $"Edit Properties – {Model.ResourceName}";
}

<h1>@Model.ResourceName — Edit Properties</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="Properties">
        <thead class="table-light">
            <tr><th>Key</th><th>Value</th><th></th></tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Properties.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="Properties[@i].Id" value="@Model.Properties[i].Id" />
                    <td><input name="Properties[@i].Key" value="@Model.Properties[i].Key" class="form-control form-control-sm" /></td>
                    <td><input name="Properties[@i].Value" value="@Model.Properties[i].Value" class="form-control form-control-sm" /></td>
                    <td><button data-remove-row class="btn btn-sm btn-danger">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="Properties">
        <tr data-row>
            <input type="hidden" name="Properties[-1].Id" value="0" />
            <td><input name="Properties[-1].Key" class="form-control form-control-sm" /></td>
            <td><input name="Properties[-1].Value" class="form-control form-control-sm" /></td>
            <td><button data-remove-row class="btn btn-sm btn-danger">Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" data-add-for="Properties" class="btn btn-sm btn-outline-secondary mb-3">Add Property</button>
    <div>
        <button id="save-submit" type="submit" class="btn btn-primary">Save</button>
        <a asp-page="../Details/Properties" asp-route-id="@HttpContext.Request.RouteValues["id"]" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
