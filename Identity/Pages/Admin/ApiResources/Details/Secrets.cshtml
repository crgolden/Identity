@page "{id:int}"
@model Identity.Pages.Admin.ApiResources.Details.SecretsModel
@{
    ViewData["Title"] = $"Secrets – {Model.Resource.Name}";
}

<h1>@Model.Resource.Name — Secrets</h1>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr>
            <th>Description</th>
            <th>Type</th>
            <th>Expiration</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var secret in Model.Secrets)
        {
            <tr>
                <td>@secret.Description</td>
                <td>@secret.Type</td>
                <td>@secret.Expiration</td>
                <td>@secret.Created</td>
            </tr>
        }
    </tbody>
</table>

<a id="btn-edit" asp-page="../Edit/Secrets" asp-route-id="@Model.Resource.Id" class="btn btn-primary">Edit</a>
<a id="btn-back" asp-page="./Index" asp-route-id="@Model.Resource.Id" class="btn btn-outline-secondary">Back</a>
