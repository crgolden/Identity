@page
@model Identity.Pages.Admin.Roles.IndexModel

@{
    ViewData["Title"] = "Roles";
}

<h1>Roles</h1>

<p>
    <a id="btn-create" asp-page="./Create" class="btn btn-primary">Create New</a>
</p>

<div class="table-responsive">
<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr>
            <th>Name</th>
            <th class="visually-hidden">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model.Roles)
        {
            <tr>
                <td>@role.Name</td>
                <td>
                    <a id="details-@role.Id" asp-page="./Details/Index" asp-route-id="@role.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a id="edit-@role.Id" asp-page="./Edit/Index" asp-route-id="@role.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a id="delete-@role.Id" asp-page="./Delete" asp-route-id="@role.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

<a id="btn-back" asp-page="/Admin/Index" class="btn btn-outline-secondary">Back</a>
