@page "{id}"
@model Identity.Pages.Admin.Roles.Edit.ClaimsModel

@{
    ViewData["Title"] = "Edit Role Claims";
}

<h1>Claims — @Model.RoleName</h1>

<form method="post">
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Type</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Claims.Count; i++)
            {
                <tr>
                    <td><input id="claim-type-@i" name="Claims[@i].Type" value="@Model.Claims[i].Type" class="form-control form-control-sm" aria-label="Claim type" /></td>
                    <td><input id="claim-value-@i" name="Claims[@i].Value" value="@Model.Claims[i].Value" class="form-control form-control-sm" aria-label="Claim value" /></td>
                    <td><button id="claim-remove-@i" type="submit" asp-page-handler="RemoveRow" asp-route-id="@HttpContext.Request.RouteValues["id"]" asp-route-index="@i" class="btn btn-sm btn-outline-danger">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <button id="btn-add-row" type="submit" asp-page-handler="AddRow" asp-route-id="@HttpContext.Request.RouteValues["id"]" class="btn btn-outline-secondary btn-sm mb-3">Add Claim</button>
    <div class="d-flex gap-2">
        <button id="save-submit" type="submit" asp-route-id="@HttpContext.Request.RouteValues["id"]" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Roles/Details/Claims" asp-route-id="@HttpContext.Request.RouteValues["id"]" class="btn btn-secondary">Cancel</a>
    </div>
</form>
