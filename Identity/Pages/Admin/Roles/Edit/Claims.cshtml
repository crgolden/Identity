@page "{id}"
@model Identity.Pages.Admin.Roles.Edit.ClaimsModel

@{
    ViewData["Title"] = "Edit Role Claims";
}

<h1>Claims — @Model.RoleName</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="Claims">
        <thead class="table-light">
            <tr>
                <th>Type</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Claims.Count; i++)
            {
                <tr data-row>
                    <td><input name="Claims[@i].Type" value="@Model.Claims[i].Type" class="form-control form-control-sm" aria-label="Claim type" /></td>
                    <td><input name="Claims[@i].Value" value="@Model.Claims[i].Value" class="form-control form-control-sm" aria-label="Claim value" /></td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="Claims">
        <tr data-row>
            <td><input name="Claims[-1].Type" class="form-control form-control-sm" aria-label="Claim type" /></td>
            <td><input name="Claims[-1].Value" class="form-control form-control-sm" aria-label="Claim value" /></td>
            <td><button type="button" class="btn btn-sm btn-outline-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-outline-secondary btn-sm mb-3" data-add-for="Claims">Add Claim</button>
    <div class="d-flex gap-2">
        <button id="save-submit" type="submit" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Roles/Details/Claims" asp-route-id="@HttpContext.Request.RouteValues["id"]" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
