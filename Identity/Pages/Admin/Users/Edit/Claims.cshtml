@page "{id}"
@model Identity.Pages.Admin.Users.Edit.ClaimsModel
@{
    ViewData["Title"] = "Edit User Claims";
}

<h1>@Model.AppUser.UserName — Edit Claims</h1>

<form method="post" data-collection-form>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <table class="table table-bordered table-sm" data-collection="Claims">
        <thead class="table-light">
            <tr>
                <th>Type</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Claims.Count; i++)
            {
                <tr>
                    <td>
                        <input asp-for="Claims[i].Type" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input asp-for="Claims[i].Value" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-danger" data-remove-row>Remove</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <button id="btn-add-row" type="button" class="btn btn-outline-secondary btn-sm mb-3" data-add-for="Claims">Add Claim</button>
    <div>
        <button id="save-submit" type="submit" class="btn btn-primary">Save</button>
        <a asp-page="../Details/Claims" asp-route-id="@Model.AppUser.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<template data-collection="Claims">
    <tr>
        <td>
            <input name="Claims[-1].Type" class="form-control form-control-sm" />
        </td>
        <td>
            <input name="Claims[-1].Value" class="form-control form-control-sm" />
        </td>
        <td>
            <button type="button" class="btn btn-sm btn-outline-danger" data-remove-row>Remove</button>
        </td>
    </tr>
</template>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
