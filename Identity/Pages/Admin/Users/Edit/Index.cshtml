@page "{id}"
@model Identity.Pages.Admin.Users.Edit.IndexModel
@{
    ViewData["Title"] = "Edit User";
}

<h1>Edit — @Model.AppUser.UserName</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="AppUser.UserName" class="form-label"></label>
        <input asp-for="AppUser.UserName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="AppUser.Email" class="form-label"></label>
        <input asp-for="AppUser.Email" class="form-control" />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="AppUser.EmailConfirmed" class="form-check-input" />
        <label asp-for="AppUser.EmailConfirmed" class="form-check-label"></label>
    </div>
    <div class="mb-3">
        <label asp-for="AppUser.PhoneNumber" class="form-label"></label>
        <input asp-for="AppUser.PhoneNumber" class="form-control" />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="AppUser.LockoutEnabled" class="form-check-input" />
        <label asp-for="AppUser.LockoutEnabled" class="form-check-label"></label>
    </div>
    <button id="save-submit" type="submit" class="btn btn-primary">Save</button>
    <a asp-page="../Details/Index" asp-route-id="@Model.AppUser.Id" class="btn btn-outline-secondary">Cancel</a>
</form>
