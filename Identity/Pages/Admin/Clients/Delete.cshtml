@page
@model DeleteModel

@{
    ViewData["Title"] = "Delete Client";
}

<h1>Delete Client</h1>
<p class="text-danger">Are you sure you want to delete this client?</p>

<dl class="row">
    <dt class="col-sm-3">Client ID</dt>
    <dd class="col-sm-9">@Model.Client.ClientId</dd>

    <dt class="col-sm-3">Client Name</dt>
    <dd class="col-sm-9">@Model.Client.ClientName</dd>

    <dt class="col-sm-3">Enabled</dt>
    <dd class="col-sm-9">@Model.Client.Enabled</dd>
</dl>

<form method="post">
    <button id="delete-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-danger">Delete</button>
    <a asp-page="./Index" class="btn btn-outline-secondary ms-1">Cancel</a>
</form>
