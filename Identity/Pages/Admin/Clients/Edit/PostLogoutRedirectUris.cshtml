@page
@model PostLogoutRedirectUrisModel

@{
    ViewData["Title"] = "Edit Client Post-Logout Redirect URIs";
}

<h1>Edit Client Post-Logout Redirect URIs</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="PostLogoutRedirectUris">
        <thead class="table-light">
            <tr>
                <th>Post-Logout Redirect URI</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.PostLogoutRedirectUris.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="PostLogoutRedirectUris[@i].Id" value="@Model.PostLogoutRedirectUris[i].Id" />
                    <td><input name="PostLogoutRedirectUris[@i].PostLogoutRedirectUri" value="@Model.PostLogoutRedirectUris[i].PostLogoutRedirectUri" class="form-control form-control-sm" aria-label="Post-logout redirect URI" /></td>
                    <td><button type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="PostLogoutRedirectUris">
        <tr data-row>
            <input type="hidden" name="PostLogoutRedirectUris[-1].Id" value="0" />
            <td><input name="PostLogoutRedirectUris[-1].PostLogoutRedirectUri" class="form-control form-control-sm" aria-label="Post-logout redirect URI" /></td>
            <td><button type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3" data-add-for="PostLogoutRedirectUris">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/PostLogoutRedirectUris" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
