@page
@model SecretsModel

@{
    ViewData["Title"] = "Edit Client Secrets";
}

<h1>Edit Client Secrets</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="Secrets">
        <thead class="table-light">
            <tr>
                <th>Description</th>
                <th>Type</th>
                <th>Expiration</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Secrets.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="Secrets[@i].Id" value="@Model.Secrets[i].Id" />
                    <td><input id="secret-description-@i" name="Secrets[@i].Description" value="@Model.Secrets[i].Description" class="form-control form-control-sm" aria-label="Description" /></td>
                    <td><input id="secret-type-@i" name="Secrets[@i].Type" value="@Model.Secrets[i].Type" class="form-control form-control-sm" aria-label="Secret type" /></td>
                    <td><input id="secret-expiration-@i" name="Secrets[@i].Expiration" value="@Model.Secrets[i].Expiration?.ToString("yyyy-MM-dd")" type="date" class="form-control form-control-sm" aria-label="Expiration" /></td>
                    <td><span class="text-muted fst-italic small">write-only once stored</span></td>
                    <td><button id="secret-remove-@i" type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="Secrets">
        <tr data-row>
            <input type="hidden" name="Secrets[-1].Id" value="0" />
            <td><input id="secret-description-IDX" name="Secrets[-1].Description" class="form-control form-control-sm" aria-label="Description" /></td>
            <td><input id="secret-type-IDX" name="Secrets[-1].Type" value="SharedSecret" class="form-control form-control-sm" aria-label="Secret type" /></td>
            <td><input id="secret-expiration-IDX" name="Secrets[-1].Expiration" type="date" class="form-control form-control-sm" aria-label="Expiration" /></td>
            <td><input id="secret-value-IDX" name="Secrets[-1].Value" placeholder="Value" class="form-control form-control-sm" aria-label="Secret value" /></td>
            <td><button id="secret-remove-IDX" type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3" data-add-for="Secrets">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/Secrets" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
