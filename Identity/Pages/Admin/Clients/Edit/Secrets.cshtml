@page
@model SecretsModel

@{
    ViewData["Title"] = "Edit Client Secrets";
}

<h1>Edit Client Secrets</h1>

<form method="post">
    <table class="table table-bordered table-sm" id="secrets-table">
        <thead class="table-light">
            <tr>
                <th>Description</th>
                <th>Type</th>
                <th>Expiration</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Secrets.Count; i++)
            {
                <tr>
                    <td>
                        <input type="hidden" name="Secrets[@i].Id" value="@Model.Secrets[i].Id" />
                        <input name="Secrets[@i].Description" value="@Model.Secrets[i].Description" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input name="Secrets[@i].Type" value="@Model.Secrets[i].Type" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input name="Secrets[@i].Expiration" value="@Model.Secrets[i].Expiration?.ToString("yyyy-MM-dd")" type="date" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <span class="text-muted fst-italic small">write-only once stored</span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger remove-row">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3">Add</button>

    <template id="row-template">
        <tr>
            <td>
                <input type="hidden" name="Secrets[__index__].Id" value="0" />
                <input name="Secrets[__index__].Description" class="form-control form-control-sm" />
            </td>
            <td>
                <input name="Secrets[__index__].Type" value="SharedSecret" class="form-control form-control-sm" />
            </td>
            <td>
                <input name="Secrets[__index__].Expiration" type="date" class="form-control form-control-sm" />
            </td>
            <td>
                <input name="Secrets[__index__].Value" placeholder="Value" class="form-control form-control-sm" />
            </td>
            <td>
                <button type="button" class="btn btn-sm btn-danger remove-row">Remove</button>
            </td>
        </tr>
    </template>

    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/Secrets" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
