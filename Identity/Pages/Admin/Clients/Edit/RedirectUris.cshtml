@page
@model RedirectUrisModel

@{
    ViewData["Title"] = "Edit Client Redirect URIs";
}

<h1>Edit Client Redirect URIs</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="RedirectUris">
        <thead class="table-light">
            <tr>
                <th>Redirect URI</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.RedirectUris.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="RedirectUris[@i].Id" value="@Model.RedirectUris[i].Id" />
                    <td><input id="redirecturi-@i" name="RedirectUris[@i].RedirectUri" value="@Model.RedirectUris[i].RedirectUri" class="form-control form-control-sm" aria-label="Redirect URI" /></td>
                    <td><button id="redirecturi-remove-@i" type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="RedirectUris">
        <tr data-row>
            <input type="hidden" name="RedirectUris[-1].Id" value="0" />
            <td><input id="redirecturi-IDX" name="RedirectUris[-1].RedirectUri" class="form-control form-control-sm" aria-label="Redirect URI" /></td>
            <td><button id="redirecturi-remove-IDX" type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3" data-add-for="RedirectUris">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/RedirectUris" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
