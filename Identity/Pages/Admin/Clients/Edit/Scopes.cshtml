@page
@model ScopesModel

@{
    ViewData["Title"] = "Edit Client Scopes";
}

<h1>Edit Client Scopes</h1>

<form method="post">
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Scope</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Scopes.Count; i++)
            {
                <tr>
                    <input type="hidden" name="Scopes[@i].Id" value="@Model.Scopes[i].Id" />
                    <td><input id="scope-@i" name="Scopes[@i].Scope" value="@Model.Scopes[i].Scope" class="form-control form-control-sm" aria-label="Scope" /></td>
                    <td><button id="scope-remove-@i" type="submit" asp-page-handler="RemoveRow" asp-route-id="@Model.Client.Id" asp-route-index="@i" class="btn btn-sm btn-danger">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <button id="btn-add-row" type="submit" asp-page-handler="AddRow" asp-route-id="@Model.Client.Id" class="btn btn-sm btn-outline-secondary mb-3">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/Scopes" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>
