@page
@model ScopesModel

@{
    ViewData["Title"] = "Edit Client Scopes";
}

<h1>Edit Client Scopes</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="Scopes">
        <thead class="table-light">
            <tr>
                <th>Scope</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Scopes.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="Scopes[@i].Id" value="@Model.Scopes[i].Id" />
                    <td><input name="Scopes[@i].Scope" value="@Model.Scopes[i].Scope" class="form-control form-control-sm" aria-label="Scope" /></td>
                    <td><button type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="Scopes">
        <tr data-row>
            <input type="hidden" name="Scopes[-1].Id" value="0" />
            <td><input name="Scopes[-1].Scope" class="form-control form-control-sm" aria-label="Scope" /></td>
            <td><button type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3" data-add-for="Scopes">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/Scopes" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
