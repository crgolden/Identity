@page
@model IdPRestrictionsModel

@{
    ViewData["Title"] = "Edit Client IdP Restrictions";
}

<h1>Edit Client IdP Restrictions</h1>

<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="IdPRestrictions">
        <thead class="table-light">
            <tr>
                <th>Provider</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.IdPRestrictions.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="IdPRestrictions[@i].Id" value="@Model.IdPRestrictions[i].Id" />
                    <td><input id="idprestriction-@i" name="IdPRestrictions[@i].Provider" value="@Model.IdPRestrictions[i].Provider" class="form-control form-control-sm" aria-label="Identity provider" /></td>
                    <td><button id="idprestriction-remove-@i" type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="IdPRestrictions">
        <tr data-row>
            <input type="hidden" name="IdPRestrictions[-1].Id" value="0" />
            <td><input id="idprestriction-IDX" name="IdPRestrictions[-1].Provider" class="form-control form-control-sm" aria-label="Identity provider" /></td>
            <td><button id="idprestriction-remove-IDX" type="button" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3" data-add-for="IdPRestrictions">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/IdPRestrictions" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/admin-collection.js"></script>
}
