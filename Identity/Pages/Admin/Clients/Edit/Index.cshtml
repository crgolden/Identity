@page
@model IndexModel

@{
    ViewData["Title"] = "Edit Client";
}

<h1>Edit Client</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Client.Id" />

    <fieldset class="mb-4">
        <legend class="h5">Identity</legend>
        <div class="mb-3">
            <label asp-for="Client.ClientId" class="form-label">Client ID</label>
            <input asp-for="Client.ClientId" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.ClientName" class="form-label">Client Name</label>
            <input asp-for="Client.ClientName" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.Description" class="form-label">Description</label>
            <input asp-for="Client.Description" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.ProtocolType" class="form-label">Protocol Type</label>
            <input asp-for="Client.ProtocolType" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.ClientUri" class="form-label">Client URI</label>
            <input asp-for="Client.ClientUri" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.LogoUri" class="form-label">Logo URI</label>
            <input asp-for="Client.LogoUri" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.InitiateLoginUri" class="form-label">Initiate Login URI</label>
            <input asp-for="Client.InitiateLoginUri" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.ClientClaimsPrefix" class="form-label">Client Claims Prefix</label>
            <input asp-for="Client.ClientClaimsPrefix" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.PairWiseSubjectSalt" class="form-label">Pair-wise Subject Salt</label>
            <input asp-for="Client.PairWiseSubjectSalt" class="form-control" />
        </div>
    </fieldset>

    <fieldset class="mb-4">
        <legend class="h5">Authentication</legend>
        <div class="form-check mb-2">
            <input asp-for="Client.Enabled" class="form-check-input" type="checkbox" />
            <label asp-for="Client.Enabled" class="form-check-label">Enabled</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.RequireClientSecret" class="form-check-input" type="checkbox" />
            <label asp-for="Client.RequireClientSecret" class="form-check-label">Require Client Secret</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.RequirePkce" class="form-check-input" type="checkbox" />
            <label asp-for="Client.RequirePkce" class="form-check-label">Require PKCE</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.AllowPlainTextPkce" class="form-check-input" type="checkbox" />
            <label asp-for="Client.AllowPlainTextPkce" class="form-check-label">Allow Plain Text PKCE</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.RequireRequestObject" class="form-check-input" type="checkbox" />
            <label asp-for="Client.RequireRequestObject" class="form-check-label">Require Request Object</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.RequireDPoP" class="form-check-input" type="checkbox" />
            <label asp-for="Client.RequireDPoP" class="form-check-label">Require DPoP</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.RequireConsent" class="form-check-input" type="checkbox" />
            <label asp-for="Client.RequireConsent" class="form-check-label">Require Consent</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.AllowRememberConsent" class="form-check-input" type="checkbox" />
            <label asp-for="Client.AllowRememberConsent" class="form-check-label">Allow Remember Consent</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.EnableLocalLogin" class="form-check-input" type="checkbox" />
            <label asp-for="Client.EnableLocalLogin" class="form-check-label">Enable Local Login</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.AllowOfflineAccess" class="form-check-input" type="checkbox" />
            <label asp-for="Client.AllowOfflineAccess" class="form-check-label">Allow Offline Access</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.AllowAccessTokensViaBrowser" class="form-check-input" type="checkbox" />
            <label asp-for="Client.AllowAccessTokensViaBrowser" class="form-check-label">Allow Access Tokens via Browser</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.AlwaysIncludeUserClaimsInIdToken" class="form-check-input" type="checkbox" />
            <label asp-for="Client.AlwaysIncludeUserClaimsInIdToken" class="form-check-label">Always Include User Claims in ID Token</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.AlwaysSendClientClaims" class="form-check-input" type="checkbox" />
            <label asp-for="Client.AlwaysSendClientClaims" class="form-check-label">Always Send Client Claims</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.IncludeJwtId" class="form-check-input" type="checkbox" />
            <label asp-for="Client.IncludeJwtId" class="form-check-label">Include JWT ID</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.UpdateAccessTokenClaimsOnRefresh" class="form-check-input" type="checkbox" />
            <label asp-for="Client.UpdateAccessTokenClaimsOnRefresh" class="form-check-label">Update Access Token Claims on Refresh</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.NonEditable" class="form-check-input" type="checkbox" />
            <label asp-for="Client.NonEditable" class="form-check-label">Non-Editable</label>
        </div>
    </fieldset>

    <fieldset class="mb-4">
        <legend class="h5">Logout</legend>
        <div class="mb-3">
            <label asp-for="Client.FrontChannelLogoutUri" class="form-label">Front-Channel Logout URI</label>
            <input asp-for="Client.FrontChannelLogoutUri" class="form-control" />
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.FrontChannelLogoutSessionRequired" class="form-check-input" type="checkbox" />
            <label asp-for="Client.FrontChannelLogoutSessionRequired" class="form-check-label">Front-Channel Logout Session Required</label>
        </div>
        <div class="mb-3">
            <label asp-for="Client.BackChannelLogoutUri" class="form-label">Back-Channel Logout URI</label>
            <input asp-for="Client.BackChannelLogoutUri" class="form-control" />
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.BackChannelLogoutSessionRequired" class="form-check-input" type="checkbox" />
            <label asp-for="Client.BackChannelLogoutSessionRequired" class="form-check-label">Back-Channel Logout Session Required</label>
        </div>
    </fieldset>

    <fieldset class="mb-4">
        <legend class="h5">Token Lifetimes</legend>
        <div class="mb-3">
            <label asp-for="Client.IdentityTokenLifetime" class="form-label">Identity Token Lifetime (s)</label>
            <input asp-for="Client.IdentityTokenLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.AllowedIdentityTokenSigningAlgorithms" class="form-label">Allowed Identity Token Signing Algorithms</label>
            <input asp-for="Client.AllowedIdentityTokenSigningAlgorithms" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.AccessTokenLifetime" class="form-label">Access Token Lifetime (s)</label>
            <input asp-for="Client.AccessTokenLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.AccessTokenType" class="form-label">Access Token Type</label>
            <input asp-for="Client.AccessTokenType" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.AuthorizationCodeLifetime" class="form-label">Authorization Code Lifetime (s)</label>
            <input asp-for="Client.AuthorizationCodeLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.ConsentLifetime" class="form-label">Consent Lifetime (s)</label>
            <input asp-for="Client.ConsentLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.AbsoluteRefreshTokenLifetime" class="form-label">Absolute Refresh Token Lifetime (s)</label>
            <input asp-for="Client.AbsoluteRefreshTokenLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.SlidingRefreshTokenLifetime" class="form-label">Sliding Refresh Token Lifetime (s)</label>
            <input asp-for="Client.SlidingRefreshTokenLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.RefreshTokenUsage" class="form-label">Refresh Token Usage</label>
            <input asp-for="Client.RefreshTokenUsage" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.RefreshTokenExpiration" class="form-label">Refresh Token Expiration</label>
            <input asp-for="Client.RefreshTokenExpiration" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.UserSsoLifetime" class="form-label">User SSO Lifetime (s)</label>
            <input asp-for="Client.UserSsoLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.DeviceCodeLifetime" class="form-label">Device Code Lifetime (s)</label>
            <input asp-for="Client.DeviceCodeLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.CibaLifetime" class="form-label">CIBA Lifetime (s)</label>
            <input asp-for="Client.CibaLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.PollingInterval" class="form-label">Polling Interval (s)</label>
            <input asp-for="Client.PollingInterval" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.PushedAuthorizationLifetime" class="form-label">Pushed Authorization Lifetime (s)</label>
            <input asp-for="Client.PushedAuthorizationLifetime" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="Client.UserCodeType" class="form-label">User Code Type</label>
            <input asp-for="Client.UserCodeType" class="form-control" />
        </div>
        <div class="form-check mb-2">
            <input asp-for="Client.RequirePushedAuthorization" class="form-check-input" type="checkbox" />
            <label asp-for="Client.RequirePushedAuthorization" class="form-check-label">Require Pushed Authorization</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="CoordinateLifetimeWithUserSession" class="form-check-input" type="checkbox" />
            <label asp-for="CoordinateLifetimeWithUserSession" class="form-check-label">Coordinate Lifetime with User Session</label>
        </div>
    </fieldset>

    <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
    <a asp-page="/Admin/Clients/Details/Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
</form>
