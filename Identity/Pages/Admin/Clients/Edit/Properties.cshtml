@page
@model PropertiesModel
@{
    ViewData["Title"] = "Edit Client Properties";
    var rows = Model.Properties.Select(p => new PropertyRow(p.Id, p.Key, p.Value)).ToList();
    var cancelHref = Url.Page("/Admin/Clients/Details/Properties", new { id = Model.Client.Id });
}

<h1>Edit Client Properties</h1>

@await Html.PartialAsync("~/Pages/Admin/Shared/_EditPropertiesForm.cshtml", rows,
    new ViewDataDictionary(ViewData) { { "CancelHref", cancelHref }, { "EntityId", Model.Client.Id } })
