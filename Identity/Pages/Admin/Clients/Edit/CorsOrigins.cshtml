@page
@model CorsOriginsModel

@{
    ViewData["Title"] = "Edit Client CORS Origins";
}

<h1>Edit Client CORS Origins</h1>

<form method="post">
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Origin</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.CorsOrigins.Count; i++)
            {
                <tr>
                    <input type="hidden" name="CorsOrigins[@i].Id" value="@Model.CorsOrigins[i].Id" />
                    <td><input id="corsorigin-@i" name="CorsOrigins[@i].Origin" value="@Model.CorsOrigins[i].Origin" class="form-control form-control-sm" aria-label="CORS origin" /></td>
                    <td><button id="corsorigin-remove-@i" type="submit" asp-page-handler="RemoveRow" asp-route-id="@Model.Client.Id" asp-route-index="@i" class="btn btn-sm btn-danger">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <button id="btn-add-row" type="submit" asp-page-handler="AddRow" asp-route-id="@Model.Client.Id" class="btn btn-sm btn-outline-secondary mb-3">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Clients/Details/CorsOrigins" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>
