@page
@model ClaimsModel

@{
    ViewData["Title"] = "Client Claims";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client Claims</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/Claims" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr>
            <th>Type</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Client.Claims ?? [])
        {
            <tr>
                <td>@c.Type</td>
                <td>@c.Value</td>
            </tr>
        }
    </tbody>
</table>
