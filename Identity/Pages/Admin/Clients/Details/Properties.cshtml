@page
@model PropertiesModel
@{
    ViewData["Title"] = "Client Properties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client Properties</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/Properties" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

@await Html.PartialAsync("~/Pages/Admin/Shared/_DetailsPropertiesTable.cshtml",
    (Model.Client.Properties ?? []).Select(p => new PropertyRow(p.Id, p.Key, p.Value)))
