@page
@model IdPRestrictionsModel

@{
    ViewData["Title"] = "Client IdP Restrictions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client IdP Restrictions</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/IdPRestrictions" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr><th>Provider</th></tr>
    </thead>
    <tbody>
        @foreach (var r in Model.Client.IdentityProviderRestrictions ?? [])
        {
            <tr><td>@r.Provider</td></tr>
        }
    </tbody>
</table>
