@page
@model ScopesModel

@{
    ViewData["Title"] = "Client Scopes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client Scopes</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/Scopes" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr><th>Scope</th></tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Client.AllowedScopes ?? [])
        {
            <tr><td>@s.Scope</td></tr>
        }
    </tbody>
</table>
