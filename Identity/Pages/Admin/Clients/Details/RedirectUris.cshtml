@page
@model RedirectUrisModel

@{
    ViewData["Title"] = "Client Redirect URIs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client Redirect URIs</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/RedirectUris" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr><th>Redirect URI</th></tr>
    </thead>
    <tbody>
        @foreach (var u in Model.Client.RedirectUris ?? [])
        {
            <tr><td>@u.RedirectUri</td></tr>
        }
    </tbody>
</table>
