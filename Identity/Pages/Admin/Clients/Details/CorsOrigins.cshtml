@page
@model CorsOriginsModel

@{
    ViewData["Title"] = "Client CORS Origins";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client CORS Origins</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/CorsOrigins" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr><th>Origin</th></tr>
    </thead>
    <tbody>
        @foreach (var o in Model.Client.AllowedCorsOrigins ?? [])
        {
            <tr><td>@o.Origin</td></tr>
        }
    </tbody>
</table>
