@page
@model GrantTypesModel

@{
    ViewData["Title"] = "Client Grant Types";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client Grant Types</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/GrantTypes" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr><th>Grant Type</th></tr>
    </thead>
    <tbody>
        @foreach (var g in Model.Client.AllowedGrantTypes ?? [])
        {
            <tr><td>@g.GrantType</td></tr>
        }
    </tbody>
</table>
