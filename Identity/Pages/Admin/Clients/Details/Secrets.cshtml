@page
@model SecretsModel

@{
    ViewData["Title"] = "Client Secrets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Client Secrets</h1>
    <div>
        <a id="btn-edit" asp-page="/Admin/Clients/Edit/Secrets" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
        <a id="btn-back" asp-page="./Index" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
        <tr>
            <th>Description</th>
            <th>Type</th>
            <th>Expiration</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Client.ClientSecrets ?? [])
        {
            <tr>
                <td>@s.Description</td>
                <td>@s.Type</td>
                <td>@s.Expiration?.ToString("u")</td>
                <td>@s.Created.ToString("u")</td>
            </tr>
        }
    </tbody>
</table>
