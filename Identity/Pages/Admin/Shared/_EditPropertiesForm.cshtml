@model IList<PropertyRow>
@{
    var cancelHref = ViewData["CancelHref"]?.ToString();
    var entityId = ViewData["EntityId"];
}
<form method="post">
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr><th>Key</th><th>Value</th><th></th></tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Count; i++)
            {
                <tr>
                    <input type="hidden" name="Properties[@i].Id" value="@Model[i].Id" />
                    <td><input id="property-key-@i" class="form-control form-control-sm" name="Properties[@i].Key" value="@Model[i].Key" aria-label="Key" /></td>
                    <td><input id="property-value-@i" class="form-control form-control-sm" name="Properties[@i].Value" value="@Model[i].Value" aria-label="Value" /></td>
                    <td><button id="property-remove-@i" type="submit" asp-page-handler="RemoveRow" asp-route-id="@entityId" asp-route-index="@i" class="btn btn-sm btn-danger">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <button id="btn-add-row" type="submit" asp-page-handler="AddRow" asp-route-id="@entityId" class="btn btn-sm btn-outline-secondary mb-3">Add</button>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@entityId" class="btn btn-primary">Save</button>
        <a href="@cancelHref" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
