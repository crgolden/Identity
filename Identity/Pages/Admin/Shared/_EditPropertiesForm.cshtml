@model IList<PropertyRow>
@{
    var cancelHref = ViewData["CancelHref"]?.ToString();
}
<form method="post" data-collection-form>
    <table class="table table-bordered table-sm" data-collection="Properties">
        <thead class="table-light">
            <tr><th>Key</th><th>Value</th><th></th></tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Count; i++)
            {
                <tr data-row>
                    <input type="hidden" name="Properties[@i].Id" value="@Model[i].Id" />
                    <td><input id="property-key-@i" class="form-control form-control-sm" name="Properties[@i].Key" value="@Model[i].Key" aria-label="Key" /></td>
                    <td><input id="property-value-@i" class="form-control form-control-sm" name="Properties[@i].Value" value="@Model[i].Value" aria-label="Value" /></td>
                    <td><button id="property-remove-@i" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
    <template data-for="Properties">
        <tr data-row>
            <input type="hidden" name="Properties[-1].Id" value="0" />
            <td><input id="property-key-IDX" class="form-control form-control-sm" name="Properties[-1].Key" aria-label="Key" /></td>
            <td><input id="property-value-IDX" class="form-control form-control-sm" name="Properties[-1].Value" aria-label="Value" /></td>
            <td><button id="property-remove-IDX" class="btn btn-sm btn-danger" data-remove-row>Remove</button></td>
        </tr>
    </template>
    <button id="btn-add-row" type="button" class="btn btn-sm btn-outline-secondary mb-3" data-add-for="Properties">Add</button>
    <div>
        <button id="save-submit" type="submit" class="btn btn-primary">Save</button>
        <a href="@cancelHref" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
