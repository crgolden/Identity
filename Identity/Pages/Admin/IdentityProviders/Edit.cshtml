@page
@model EditModel

@{
    ViewData["Title"] = "Edit Identity Provider";
}

<h1>Edit Identity Provider</h1>

<form method="post">
    <div class="mb-3">
        <label asp-for="IdentityProvider.Scheme" class="form-label"></label>
        <input asp-for="IdentityProvider.Scheme" class="form-control" />
        <span asp-validation-for="IdentityProvider.Scheme" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="IdentityProvider.DisplayName" class="form-label"></label>
        <input asp-for="IdentityProvider.DisplayName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="IdentityProvider.Type" class="form-label"></label>
        <input asp-for="IdentityProvider.Type" class="form-control" />
        <span asp-validation-for="IdentityProvider.Type" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="IdentityProvider.Properties" class="form-label"></label>
        <textarea asp-for="IdentityProvider.Properties" class="form-control" rows="4"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IdentityProvider.Enabled" class="form-check-input" />
        <label asp-for="IdentityProvider.Enabled" class="form-check-label"></label>
    </div>
    <div>
        <button id="save-submit" type="submit" asp-route-id="@Model.IdentityProvider.Id" class="btn btn-primary">Save</button>
        <a asp-page="./Details" asp-route-id="@Model.IdentityProvider.Id" class="btn btn-outline-secondary ms-1">Cancel</a>
    </div>
</form>
