@model Identity.Pages.Account.Manage.ConsentModel.ScopeViewModel

<li class="list-group-item">
    <div class="form-check @(Model.Emphasize ? "fw-bold" : null)">
        @if (Model.Required)
        {
            <input type="hidden" name="Input.ScopesConsented" value="@Model.Value" />
            <input class="form-check-input" type="checkbox" checked disabled />
        }
        else
        {
            <input class="form-check-input"
                   type="checkbox"
                   name="Input.ScopesConsented"
                   id="scope_@Model.Value"
                   value="@Model.Value"
                   checked="@Model.Checked" />
        }
        <label class="form-check-label" for="scope_@Model.Value">
            @Model.DisplayName
            @if (Model.Required)
            {
                <span class="badge text-bg-secondary ms-1">Required</span>
            }
        </label>
    </div>
    @if (!IsNullOrWhiteSpace(Model.Description))
    {
        <div class="text-muted small ms-4">@Model.Description</div>
    }
    @if (Model.Resources.Any())
    {
        <div class="text-muted small ms-4">
            Resources: @Join(", ", Model.Resources.Select(r => r.DisplayName))
        </div>
    }
</li>
