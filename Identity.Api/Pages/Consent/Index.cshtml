@page
@model Identity.Pages.Consent.IndexModel
@{
    ViewData["Title"] = "Authorize Application";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-8">
        @if (Model.View.ClientLogoUrl != null)
        {
            <div class="mb-3">
                <img src="@Model.View.ClientLogoUrl" alt="@Model.View.ClientName logo" class="img-thumbnail" style="max-height:100px" />
            </div>
        }

        <h2>
            @if (Model.View.ClientUrl != null)
            {
                <a href="@Model.View.ClientUrl" target="_blank" rel="noopener noreferrer">@Model.View.ClientName</a>
            }
            else
            {
                @Model.View.ClientName
            }
            <small class="text-muted">is requesting your permission</small>
        </h2>
        <p class="text-muted">Uncheck any permissions you do not wish to grant.</p>

        <form id="consent-form" method="post">
            <input type="hidden" asp-for="Input.ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            @if (Model.View.IdentityScopes.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <strong>Personal Information</strong>
                    </div>
                    <ul class="list-group list-group-flush">
                        @foreach (var scope in Model.View.IdentityScopes)
                        {
                            <partial name="_ScopeListItem" model="scope" />
                        }
                    </ul>
                </div>
            }

            @if (Model.View.ApiScopes.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <strong>Application Access</strong>
                    </div>
                    <ul class="list-group list-group-flush">
                        @foreach (var scope in Model.View.ApiScopes)
                        {
                            <partial name="_ScopeListItem" model="scope" />
                        }
                    </ul>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Description <span class="text-muted">(optional)</span></label>
                <input asp-for="Input.Description" class="form-control" placeholder="Describe this device or session" />
            </div>

            @if (Model.View.AllowRememberConsent)
            {
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberConsent" />
                    <label class="form-check-label" asp-for="Input.RememberConsent">
                        <strong>Remember my decision</strong>
                    </label>
                </div>
            }

            <div class="d-flex gap-2">
                <button name="Input.Button" value="yes" type="submit" class="btn btn-primary">
                    Yes, Allow
                </button>
                <button name="Input.Button" value="no" type="submit" class="btn btn-outline-secondary" formnovalidate>
                    No, Do Not Allow
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
