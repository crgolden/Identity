@page
@model Identity.Pages.Ciba.IndexModel
@{
    ViewData["Title"] = "Login Request";
}

<h1>@ViewData["Title"]</h1>

@if (Model.LoginRequest != null)
{
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">
                    <strong>@(Model.LoginRequest.Client.ClientName ?? Model.LoginRequest.Client.ClientId)</strong>
                    <small class="text-muted">is requesting your authorization</small>
                </div>
                <div class="card-body">
                    @if (!IsNullOrWhiteSpace(Model.LoginRequest.BindingMessage))
                    {
                        <p>
                            <span class="text-muted">Binding message:</span>
                            <strong>@Model.LoginRequest.BindingMessage</strong>
                        </p>
                    }
                    <p class="text-muted small">
                        Please confirm this request is legitimate and that it originated from a trusted device.
                        Do not approve if you did not initiate this request.
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning" role="alert">
        This backchannel authentication request could not be found or has expired.
    </div>
}
